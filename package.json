{
  "name": "gpt-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "commitlint": "commitlint --edit",
    "format": "prettier --ignore-path .prettierignore --ignore-path .gitignore --check \"**/*.+(js|json|ts|tsx)\"",
    "format:fix": "prettier --ignore-path .prettierignore --ignore-path .gitignore --write \"**/*.+(js|json|ts|tsx)\"",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --max-warnings=0 --fix",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "validate": "npm-run-all --parallel typecheck lint format",
    "validate-and-build": "npm-run-all validate build",
    "deploy": "npm-run-all validate-and-build start"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mistralai/mistralai": "^2.1.1",
    "@tanstack/react-query": "^5.95.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tanstack/eslint-plugin-query": "^5.95.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "clsx": "2.1.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-tailwindcss": "3.18.2",
    "husky": "9.1.7",
    "npm-run-all": "4.1.5",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.19",
    "typescript": "^5.9.3"
  }
}
